{
  "name": "project-manager-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run test:coverage && npm run test:e2e",
    "test:unit": "node --test tests/unit",
    "test:coverage": "c8 --reporter=text --reporter=text-summary --reporter=html --reporter=lcov --reporter=json-summary --include=logic.mjs --check-coverage --lines 90 --functions 90 --branches 85 --statements 90 node --test tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "c8": "^10.1.3"
  }
}
